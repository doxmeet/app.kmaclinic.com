# Dev deploy (pnpm build:dev / start:dev). Points at the dev API.
VITE_API_URL=https://api-dev.kmaclinic.com

# Doxmeet OAuth — 같은 클라이언트(kmaclinic_com).
# ⚠ dev redirect(app-dev)이 Doxmeet 측에 등록돼 있어야 동작합니다(미등록 시 invalid_redirect). client_secret 은 백엔드 전용.
VITE_DOXMEET_AUTHORIZE_URL=https://www-dev.doxmeet.com/oauth/authorize
VITE_DOXMEET_CLIENT_ID=kmaclinic_com_dev
VITE_DOXMEET_SCOPE=read:user
VITE_OAUTH_REDIRECT_URI=https://app-dev.kmaclinic.com/oauth/doxmeet/callback
VITE_TOSS_CLIENT_KEY=test_ck_AQ92ymxN34Z00A22gDggrajRKXvd
# 실시간 미리보기 앱 origin (preview-integration.md §2).
# 미리보기 앱(wildcard.kmaclinic.com)은 dev 환경이 없어 dev도 prod preview를 쓴다.
VITE_PREVIEW_ORIGIN=https://preview.kmaclinic.com

# 의사 프로필 미리보기 앱 origin (editor-preview-integration.md §4). dev 없음 → 모든 환경 prod.
VITE_PROFILE_PREVIEW_ORIGIN=https://wildcard.kmadoc.com
