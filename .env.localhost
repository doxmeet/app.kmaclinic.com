# Local development (pnpm dev, --mode localhost). Points at the local API.
VITE_API_URL=https://api-local.kmaclinic.com

# Doxmeet OAuth — 로컬에서 실제 로그인까지 테스트하려면 아래 주석을 해제하세요.
# 단 redirect(http://localhost:3000/oauth/doxmeet/callback)가 Doxmeet 측에 등록돼 있어야 합니다.
# 미설정이면 로그인 버튼은 안내(stub) 상태로 동작합니다. client_secret 은 프론트에 두지 마세요.
VITE_DOXMEET_AUTHORIZE_URL=https://www-dev.doxmeet.com/oauth/authorize
VITE_DOXMEET_CLIENT_ID=kmaclinic_com_local
VITE_DOXMEET_SCOPE=read:user
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/doxmeet/callback

# GGKMA(경기도의사회) OAuth — ggkma-oauth-frontend-guide §2.
# 로컬 redirect(http://localhost:3000/oauth/ggkma/callback)가 GGKMA 측에 등록돼 있어야 하고
# 반드시 포트 3000으로 띄워야 합니다(pnpm dev). 미설정이면 로그인 버튼은 안내(stub) 상태.
# authorize = GGKMA 로컬 웹 프론트(localhost:5173/oauth/authorize). api 계열·/authorize/session 아님(내부용).
# ※ GGKMA 로컬 프론트를 띄우기 어려우면 dev GGKMA(www-dev.ggkma.org)로 통합 테스트 — 단 client_id/redirect_uri를
#   dev 등록값(kmaclinic_com_dev)으로 맞춰야 함(GGKMA 팀과 협의).
VITE_GGKMA_AUTHORIZE_URL=https://www-dev.ggkma.org/oauth/authorize
VITE_GGKMA_CLIENT_ID=kmaclinic_com_local
VITE_GGKMA_SCOPE=profile license workplace
VITE_GGKMA_REDIRECT_URI=http://localhost:3000/oauth/ggkma/callback
VITE_TOSS_CLIENT_KEY=test_ck_AQ92ymxN34Z00A22gDggrajRKXvd
# 실시간 미리보기 앱 origin (preview-integration.md §2).
# 미리보기 앱(wildcard.kmaclinic.com)은 dev 환경이 없어 로컬/dev도 prod preview를 쓴다.
# (로컬 콘솔 origin이 preview 앱 허용목록에 등록돼 있어야 메시지가 반영됨 — §8)
VITE_PREVIEW_ORIGIN=https://preview.kmaclinic.com

# 의사 프로필 미리보기 앱 origin (editor-preview-integration.md §4). dev 없음 → 모든 환경 prod.
VITE_PROFILE_PREVIEW_ORIGIN=https://preview.kmadoc.com
