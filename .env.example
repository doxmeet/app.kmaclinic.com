# Backend REST API base URL (no trailing slash).
# Selected automatically by run mode via .env.<mode> files:
#   pnpm dev                  -> .env.development  (local backend)
#   vite build --mode staging -> .env.staging      (api-dev.kmaclinic.com)
#   pnpm build                -> .env.production    (api.kmaclinic.com)
# Override locally (uncommitted) with .env.local or .env.development.local
VITE_API_URL=http://localhost:4000
